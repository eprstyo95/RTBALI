# REQUIRED — the webhook and web API now fail closed if these are unset.
TELEGRAM_BOT_TOKEN=123456:replace-with-botfather-token
TELEGRAM_WEBHOOK_SECRET=replace-with-random-webhook-secret
RTBALI_SYNC_KEY=replace-with-web-sync-key

RTBALI_TRIP_ID=rtbali
RTBALI_LINK_CODE=replace-with-group-link-code
RTBALI_ALLOWED_CHAT_ID=
RTBALI_STORAGE_BUCKET=

# Optional. Comma-separated browser origins allowed to call the web API.
# Default "*" allows any origin (safe: the API requires the x-rtbali-sync-key header).
RTBALI_ALLOWED_ORIGINS=*
# Optional. Minimum ms between OCR/photo requests per chat (Vision cost guard). Default 3000.
RTBALI_OCR_MIN_INTERVAL_MS=3000

